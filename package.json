{
  "name": "pi-rpc-vscode",
  "displayName": "Pi RPC",
  "description": "Direct VS Code integration for Pi 0.80.10 RPC mode",
  "version": "0.0.1",
  "publisher": "local",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://example.invalid/local/pi-rpc-vscode.git"
  },
  "engines": {
    "vscode": "^1.95.0",
    "node": ">=22.19.0"
  },
  "categories": [
    "Other",
    "Chat",
    "Machine Learning"
  ],
  "keywords": [
    "pi",
    "rpc",
    "chat",
    "agent",
    "assistant"
  ],
  "icon": "media/icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "workspace"
  ],
  "files": [
    "dist",
    "media",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE"
