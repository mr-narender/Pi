{
  "name": "pi",
  "displayName": "Pi – this one is (y)ours",
  "description": "An unofficial, personal VS Code chat UI for the Pi coding agent (pi.dev). Not affiliated with pi.dev — shared for anyone who wants it.",
  "version": "0.0.50",
  "publisher": "mr-narender",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mr-narender/Pi.git"
  },
  "engines": {
    "vscode": "^1.75.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "Other",
    "Chat",
    "Machine Learning"
  ],
  "keywords": [
    "pi",
    "rpc",
    "chat",
    "agent",
    "assistant"
  ],
  "icon": "media/icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCustomEditor:piRpc.chatEditor"
  ],
  "extensionKind": [
    "workspace"
  ],
  "files": [
    "dist",
    "media",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "clean": "rm -rf dist .tmp coverage *.vsix",
    "build": "npm run clean && node ./scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p test/tsconfig.json --noEmit",
    "lint": "eslint src test scripts",
    "format:check": "prettier --check .",
    "validate:coverage": "node ./scripts/validateCoverage.mjs",
    "test": "npm run validate:coverage && npm run test:unit && npm run test:integration && npm run test:extension",
    "test:unit": "node --import tsx --test test/unit/**/*.test.ts",
    "test:integration": "node --import tsx --test test/integration/**/*.test.ts",
    "test:extension": "node --import tsx test/extension/run.ts",
    "smoke:real-pi": "node --import tsx --test test/integration/real-pi-smoke.test.ts",
    "package:vsix": "npm run build && npx @vscode/vsce package --no-dependencies --allow-missing-repository",
    "audit:prod": "npm audit --omit=dev"
  },
  "dependencies": {
    "markdown-it": "14.3.0"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "@types/vscode": "1.75.0",
    "@typescript-eslint/eslint-plugin": "8.46.2",
    "@typescript-eslint/parser": "8.46.2",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.6.1",
    "esbuild": "0.25.12",
    "eslint": "9.39.1",
    "prettier": "3.6.2",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  },
