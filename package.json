    "configuration": {
      "title": "Pi",
      "properties": {
        "piRpc.executable": {
          "type": "string",
          "default": "pi",
          "description": "Pi executable resolved on the workspace extension host."
        },
        "piRpc.additionalArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional non-secret Pi CLI arguments. --api-key is rejected."
        },
        "piRpc.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Start Pi automatically when a trusted file workspace is opened."
        },
        "piRpc.offline": {
          "type": "boolean",
          "default": true,
          "description": "Launch Pi with --offline by default."
        },
        "piRpc.allowApproveInTrustedWorkspace": {
          "type": "boolean",
          "default": false,
          "description": "Allow --approve after explicit confirmation in trusted workspaces."
        },
        "piRpc.responseTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "description": "Default RPC response timeout in milliseconds for short-lived commands."
        },
        "piRpc.longRunningTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 1000,
          "description": "Default RPC response timeout in milliseconds for long-running commands like bash and export."
        },
        "piRpc.maxRecordBytes": {
          "type": "number",
          "default": 16777216,
          "minimum": 1024,
          "description": "Maximum JSONL record size accepted from Pi stdout. Large enough to resume sessions with big messages or tool outputs."
        },
        "piRpc.maxPendingRequests": {
          "type": "number",
          "default": 256,
          "minimum": 1,
          "description": "Maximum in-flight correlated RPC requests per controller."
        },
        "piRpc.messageWindowSize": {
          "type": "number",
          "default": 50,
          "minimum": 10,
          "description": "How many recent messages to render when opening a chat. Older messages load on demand as you scroll up, keeping large sessions fast."
        },
        "piRpc.maxQueuedWrites": {
          "type": "number",
          "default": 256,
          "minimum": 1,
          "description": "Maximum queued outbound writes per controller."
        },
        "piRpc.maxTranscriptItems": {
          "type": "number",
          "default": 400,
          "minimum": 10,
          "description": "Maximum retained transcript items in the webview snapshot."
        },
        "piRpc.maxToolOutputChars": {
          "type": "number",
          "default": 20000,
          "minimum": 256,
          "description": "Maximum tool output characters rendered in VS Code surfaces before truncation."
        },
        "piRpc.maxImageBytes": {
          "type": "number",
          "default": 3145728,
          "minimum": 1024,
          "description": "Maximum accepted attachment size per image before local rejection."
        },
        "piRpc.maxImagesPerPrompt": {
          "type": "number",
          "default": 4,
          "minimum": 0,
          "description": "Maximum images attached to one prompt."
        },
        "piRpc.restartOnCrash": {
          "type": "boolean",
          "default": true,
          "description": "Automatically restart the owned Pi process after an unexpected exit."
        },
        "piRpc.maxRestartAttempts": {
          "type": "number",
          "default": 3,
          "minimum": 0,
          "description": "Maximum automatic restart attempts after unexpected exits."
        },
        "piRpc.telemetryEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Reserved local extension telemetry switch. No telemetry is sent by default."
        },
        "piRpc.defaultViewMode": {
          "type": "string",
          "enum": [
            "simple",
            "advanced"
          ],
          "default": "simple",
          "description": "Default Pi UI mode. Simple keeps chat focused. Advanced keeps the Advanced panel visible."
        },
        "piRpc.editorTabs.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Open Pi chats as native editor tabs backed by pi-chat: resources. Turn off only to roll back to the legacy shared panel during migration."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "piRpcInternal.openChat",
          "when": "resourceScheme == file || resourceScheme == untitled || resourceScheme == pi-chat",
          "group": "navigation@1"
        },
        {
          "command": "piRpc.newSession",
          "when": "resourceScheme == file || resourceScheme == untitled || resourceScheme == pi-chat",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "piRpcInternal.deleteSession",
          "when": "false"
        },
        {
          "command": "piRpcInternal.renameSession",
          "when": "false"
        }
      ]
    }
  },
  "homepage": "https://github.com/mr-narender/Pi#readme",
  "bugs": {
